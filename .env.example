# .env.example - Environment Variables for SCMD Pro
#
# Source-control contract:
# - Commit this example file.
# - Never commit the real `.env`.
# - Use placeholder values only; production must override every secret.

# --- Django core settings ---
DEBUG=True
ENVIRONMENT=development
SECRET_KEY=change-me
SIMPLE_JWT_SIGNING_KEY=change-me
FIELD_ENCRYPTION_KEY=base64-encoded-32-byte-key-required-in-production
# Optional legacy alias accepted by settings.py:
# ENCRYPTION_KEY=base64-encoded-32-byte-key-required-in-production
EXCEL_EXPORT_PASSWORD=change-me

ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
SCMD_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001

# --- Database configuration ---
# Local development may intentionally omit DATABASE_URL to use SQLite when DEBUG=True.
# Docker production/demo must use PostGIS via service host `db`.
SQL_DATABASE=scmd_pro
SQL_USER=scmd_user
SQL_PASSWORD=change-me
POSTGRES_DB=scmd_pro
POSTGRES_USER=scmd_user
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgis://scmd_user:change-me@db:5432/scmd_pro
# Optional local PostGIS development example outside Docker:
# DATABASE_URL=postgis://user:password@localhost:5432/scmd_db
# SQLite is development-only and forbidden under docker-compose.prod.yml:
# DATABASE_URL=sqlite:///db.sqlite3

# --- Docker compose runtime contract ---
SCMD_DOCKER_COMPOSE=
SCMD_DOCKER_PROD_MODE=0

# --- GeoDjango native runtime (Windows development) ---
# Example:
# OSGEO4W_ROOT=C:\OSGeo4W

# --- Redis / async runtime ---
REDIS_URL=redis://redis:6379/0

# --- Bootstrap credentials ---
SCMD_ADMIN_PASSWORD=change-me
SCMD_SEED_PASS=change-me

# --- Security flags ---
SECURE_SSL_REDIRECT=False

# --- External integrations ---
GOOGLE_MAPS_API_KEY=change-me
GEMINI_API_KEY=change-me

# --- Frontend asset build ---
NODE_ENV=development
PORT=3000
